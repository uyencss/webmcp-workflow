{
  "name": "@gyga-browser/webmcp-workflow",
  "version": "0.3.1",
  "description": "CLI for validating and executing WebMCP workflow JSON through a gateway.",
  "license": "MIT",
  "author": "uyencss",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uyencss/webmcp-workflow.git"
  },
  "homepage": "https://github.com/uyencss/webmcp-workflow#readme",
  "bugs": {
    "url": "https://github.com/uyencss/webmcp-workflow/issues"
  },
  "keywords": [
    "webmcp",
    "workflow",
    "browser-automation",
    "cli",
    "gateway",
    "mcp"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "webmcp-workflow": "bin/webmcp-workflow-cli.js",
    "webmcp-workflow-cli": "bin/webmcp-workflow-cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/install-agent.mjs",
    "skills/webmcp-workflow-cli/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/webmcp-workflow-cli.js",
    "test": "node --test tests/*.test.js",
    "test:workflow": "node tests/run-workflow-smoke.js",
    "link:local": "npm link",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm test",
    "install:agent": "node scripts/install-agent.mjs",
    "install:local": "node scripts/install-agent.mjs local",
    "install:codex": "node scripts/install-agent.mjs codex",
    "install:claude": "node scripts/install-agent.mjs claude",
    "install:gemini": "node scripts/install-agent.mjs gemini",
    "install:antigravity": "node scripts/install-agent.mjs antigravity",
    "install:cursor": "node scripts/install-agent.mjs cursor",
    "install:copilot": "node scripts/install-agent.mjs copilot"
  },
  "engines": {
    "node": ">=18"
  }
}
